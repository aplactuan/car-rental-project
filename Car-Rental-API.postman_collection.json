								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/availability?type=car&start=2025-03-01&end=2025-03-31",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "availability"],
							"query": [
								{
									"key": "type",
									"value": "car",
									"description": "Required: 'car' or 'driver'"
								},
								{
									"key": "start",
									"value": "2025-03-01",
									"description": "Required: Start date"
								},
								{
									"key": "end",
									"value": "2025-03-31",
