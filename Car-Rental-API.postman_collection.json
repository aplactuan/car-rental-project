		{
			"name": "Billing & bills",
			"description": "All routes here require **Bearer** auth. Query keys below are optional unless noted.",
			"item": [
				{
					"name": "Billing summary",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/billing/summary?filter[customer_id]={{customer_id}}&filter[as_of]=2026-05-01&filter[paid_at][from]=2026-01-01&filter[paid_at][to]=2026-12-31",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "billing", "summary"],
							"query": [
								{
									"key": "filter[customer_id]",
									"value": "{{customer_id}}",
									"description": "Optional. UUID of a customer; scopes summary to that customer."
								},
								{
									"key": "filter[as_of]",
									"value": "2026-05-01",
									"description": "Optional. Date boundary for summary."
								},
								{
									"key": "filter[paid_at][from]",
									"value": "2026-01-01",
									"description": "Optional. Use with filter[paid_at][to]; paid_at to must be on or after from."
								},
								{
									"key": "filter[paid_at][to]",
									"value": "2026-12-31",
									"description": "Optional. Paid-at range end."
								}
							]
						},
						"description": "**Bearer required.** Aggregated billing for the authenticated user. All `filter[...]` query keys are optional; omit `filter` entirely for an unfiltered summary."
					}
				},
				{
					"name": "List bills (all)",
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Accept",
								"value": "application/json"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/v1/bills?per_page=15&sort=-issued_at&include=transaction&filter[status]=draft,issued&filter[issued_at][from]=2026-01-01&filter[issued_at][to]=2026-12-31",
							"host": ["{{base_url}}"],
							"path": ["api", "v1", "bills"],
							"query": [
								{
									"key": "per_page",
									"value": "15",
									"description": "Optional. 1–100, default 15."
								},
								{
									"key": "sort",
									"value": "-issued_at",
									"description": "Optional. One of: issued_at, -issued_at, created_at, -created_at."
								},
								{
									"key": "include",
									"value": "transaction",
									"description": "Optional. If set to `transaction` (comma-separated list allowed but only this token is valid), response adds `included` with related transactions."
								},
								{
									"key": "filter[status]",
									"value": "draft,issued",
									"description": "Optional. Comma-separated: draft, issued, paid, cancelled."
								},
								{
									"key": "filter[issued_at][from]",
									"value": "2026-01-01",
									"description": "Optional. Use with filter[issued_at][to]."
								},
								{
									"key": "filter[issued_at][to]",
									"value": "2026-12-31",
									"description": "Optional. Must be on or after from when both set."
								}
							]
						},
						"description": "**Bearer required.** Paginated bills for the current user across all customers."
					}
				}
			]
		},
